{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Narration Plan",
  "type": "object",
  "required": [
    "mode",
    "chunks"
  ],
  "properties": {
    "mode": {
      "enum": [
        "single_session",
        "directed_chunks"
      ]
    },
    "global_instruction": {
      "type": "string"
    },
    "chunks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "instruction": {
            "type": "string"
          },
          "pause_after_ms": {
            "type": "integer",
            "minimum": 0,
            "maximum": 30000
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
