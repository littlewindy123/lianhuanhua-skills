{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lianhuanhua Studio State",
  "type": "object",
  "required": [
    "stage",
    "action"
  ],
  "properties": {
    "stage": {
      "enum": [
        "create",
        "voice",
        "storyboard",
        "images",
        "video"
      ]
    },
    "action": {
      "enum": [
        "generate_voice",
        "generate_full_project",
        "generate_storyboard_and_prompts",
        "generate_all_panels",
        "regenerate_panel",
        "validate_manual_panels",
        "render_video",
        "confirm_voice",
        "confirm_storyboard",
        "confirm_images"
      ]
    },
    "panel_id": {
      "type": "string",
      "pattern": "^panel_[0-9]{3}$"
    },
    "feedback": {
      "type": "string"
    },
    "prompt": {
      "type": "string"
    },
    "image_provider": {
      "enum": [
        "codex",
        "external"
      ]
    },
    "node_status": {
      "type": "object",
      "properties": {
        "voice": {
          "enum": [
            "pending",
            "running",
            "ready",
            "confirmed",
            "failed"
          ]
        },
        "storyboard": {
          "enum": [
            "pending",
            "running",
            "ready",
            "confirmed",
            "failed"
          ]
        },
        "images": {
          "enum": [
            "pending",
            "running",
            "ready",
            "confirmed",
            "failed"
          ]
        },
        "video": {
          "enum": [
            "pending",
            "running",
            "ready",
            "confirmed",
            "failed"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
