{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Character Bible",
  "type": "object",
  "required": [
    "character_id",
    "summary",
    "immutable_features",
    "mutable_features",
    "forbidden_changes"
  ],
  "properties": {
    "character_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "user_identity_hint": {
      "type": "string"
    },
    "reference_images": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "immutable_features": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "array"
        ]
      }
    },
    "mutable_features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_changes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertain_features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "character_sheet": {
      "type": [
        "string",
        "null"
      ]
    },
    "identity_research": {
      "type": "object",
      "required": [
        "status",
        "is_known_ip",
        "ip_name",
        "aliases",
        "creator_or_owner",
        "source_urls",
        "confidence",
        "observable_traits",
        "prompt_identity"
      ],
      "properties": {
        "status": {
          "enum": [
            "pending",
            "not_needed",
            "searched",
            "identified",
            "unidentified"
          ]
        },
        "is_known_ip": {
          "type": "boolean"
        },
        "ip_name": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "creator_or_owner": {
          "type": "string"
        },
        "source_urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "observable_traits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prompt_identity": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
